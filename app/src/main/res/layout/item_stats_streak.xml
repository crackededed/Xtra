<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainer"
    app:cardCornerRadius="@dimen/stats_card_corner_radius"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/stats_compact_card_min_height"
        android:padding="@dimen/stats_card_inner_padding">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/centerGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <ImageView
            android:id="@+id/currentStreakIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/baseline_local_fire_department_24"
            app:layout_constraintEnd_toStartOf="@id/centerGuide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FF6B6B" />

        <TextView
            android:id="@+id/currentStreakText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/centerGuide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/currentStreakIcon"
            tools:text="5" />

        <TextView
            android:id="@+id/currentStreakLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/current_streak"
            android:textAllCaps="true"
            android:textColor="?android:textColorSecondary"
            android:textSize="10sp"
            app:layout_constraintEnd_toStartOf="@id/centerGuide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/currentStreakText" />

        <View
            android:id="@+id/streakDivider"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="?attr/colorOutlineVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/centerGuide"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/longestStreakIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/baseline_emoji_events_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/centerGuide"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFD93D" />

        <TextView
            android:id="@+id/longestStreakText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/centerGuide"
            app:layout_constraintTop_toBottomOf="@id/longestStreakIcon"
            tools:text="12" />

        <TextView
            android:id="@+id/longestStreakLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/longest_streak"
            android:textAllCaps="true"
            android:textColor="?android:textColorSecondary"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/centerGuide"
            app:layout_constraintTop_toBottomOf="@id/longestStreakText" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
