<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainer"
    app:cardCornerRadius="@dimen/stats_card_corner_radius"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/stats_card_inner_padding">

        <ImageView
            android:id="@+id/headerIcon"
            android:layout_width="@dimen/stats_header_icon_size"
            android:layout_height="@dimen/stats_header_icon_size"
            android:src="@drawable/baseline_schedule_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?android:textColorSecondary" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/stats_header_icon_margin"
            android:text="@string/peak_viewing_times"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/headerIcon"
            app:layout_constraintStart_toEndOf="@id/headerIcon"
            app:layout_constraintTop_toTopOf="@id/headerIcon" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/last_30_days"
            android:textColor="?android:textColorSecondary"
            android:textSize="12sp"
            app:layout_constraintBaseline_toBaselineOf="@id/titleText"
            app:layout_constraintStart_toEndOf="@id/titleText" />

        <com.github.andreyasadchy.xtra.ui.view.HourlyHeatmapView
            android:id="@+id/hourlyHeatmap"
            android:layout_width="0dp"
            android:layout_height="@dimen/stats_heatmap_height"
            android:layout_marginTop="@dimen/stats_section_spacing"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerIcon" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
