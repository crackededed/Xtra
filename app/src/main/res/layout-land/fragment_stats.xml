<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/stats_page_padding">

        <!-- Screen Time Overview Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/stats_section_spacing"
            app:cardCornerRadius="@dimen/stats_card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/stats_card_inner_padding">

                <!-- Header with icon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/stats_section_spacing">

                    <ImageView
                        android:layout_width="@dimen/stats_header_icon_size"
                        android:layout_height="@dimen/stats_header_icon_size"
                        android:src="@drawable/baseline_access_time_24"
                        app:tint="?android:textColorSecondary"
                        android:layout_marginEnd="@dimen/stats_header_icon_margin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/screen_time"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Daily Average -->
                <TextView
                    android:id="@+id/dailyAverageText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"
                    tools:text="3h 37m" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_average"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="13sp" />

                <!-- Week Change -->
                <TextView
                    android:id="@+id/weekChangeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="↑ 49% from last week" />

                <!-- Bar Chart -->
                <com.github.andreyasadchy.xtra.ui.view.DailyBarChartView
                    android:id="@+id/dailyBarChart"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="@dimen/stats_section_spacing" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/stats_section_spacing"
                    android:background="?attr/colorOutlineVariant" />

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stats_section_spacing"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/today"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/todayTimeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="18 min" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/last_7_days"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/weekTotalText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="25h 16m" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Watch Streak Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/streakCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/stats_section_spacing"
            app:cardCornerRadius="@dimen/stats_card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/stats_card_min_height">

                <!-- Current Streak -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/baseline_local_fire_department_24"
                        app:tint="#FF6B6B" />

                    <TextView
                        android:id="@+id/currentStreakText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"
                        tools:text="5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/current_streak"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginVertical="20dp"
                    android:background="?attr/colorOutlineVariant" />

                <!-- Longest Streak -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/baseline_emoji_events_24"
                        app:tint="#FFD93D" />

                    <TextView
                        android:id="@+id/longestStreakText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"
                        tools:text="12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/longest_streak"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Category Breakdown Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/stats_section_spacing"
            app:cardCornerRadius="@dimen/stats_card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/stats_card_inner_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/stats_section_spacing">

                    <ImageView
                        android:layout_width="@dimen/stats_header_icon_size"
                        android:layout_height="@dimen/stats_header_icon_size"
                        android:src="@drawable/baseline_pie_chart_24"
                        app:tint="?android:textColorSecondary"
                        android:layout_marginEnd="@dimen/stats_header_icon_margin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/categories_watched"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.github.andreyasadchy.xtra.ui.view.CategoryPieChartView
                    android:id="@+id/categoryPieChart"
                    android:layout_width="match_parent"
                    android:layout_height="160dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/categoryLegendRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stats_card_gutter"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Peak Viewing Times Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/stats_section_spacing"
            app:cardCornerRadius="@dimen/stats_card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/stats_card_inner_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/stats_section_spacing">

                    <ImageView
                        android:layout_width="@dimen/stats_header_icon_size"
                        android:layout_height="@dimen/stats_header_icon_size"
                        android:src="@drawable/baseline_schedule_24"
                        app:tint="?android:textColorSecondary"
                        android:layout_marginEnd="@dimen/stats_header_icon_margin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/peak_viewing_times"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/last_30_days"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="11sp"
                        android:background="?attr/colorSurfaceContainerHigh"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

                <com.github.andreyasadchy.xtra.ui.view.HourlyHeatmapView
                    android:id="@+id/hourlyHeatmap"
                    android:layout_width="match_parent"
                    android:layout_height="44dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Streamer Loyalty Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/loyaltyCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/stats_section_spacing"
            app:cardCornerRadius="@dimen/stats_card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/stats_card_inner_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/stats_section_spacing">

                    <ImageView
                        android:layout_width="@dimen/stats_header_icon_size"
                        android:layout_height="@dimen/stats_header_icon_size"
                        android:src="@drawable/baseline_local_fire_department_24"
                        app:tint="?android:textColorSecondary"
                        android:layout_marginEnd="@dimen/stats_header_icon_margin" />

                    <TextView
                        android:id="@+id/loyaltyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/streamer_loyalty"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/loyaltyRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/loyaltyEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:text="@string/no_data"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Top Watched Channels Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/topStreamsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/stats_section_spacing"
            app:cardCornerRadius="@dimen/stats_card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/stats_card_inner_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/stats_section_spacing">

                    <ImageView
                        android:layout_width="@dimen/stats_header_icon_size"
                        android:layout_height="@dimen/stats_header_icon_size"
                        android:src="@drawable/baseline_pie_chart_24"
                        app:tint="?android:textColorSecondary"
                        android:layout_marginEnd="@dimen/stats_header_icon_margin" />

                    <TextView
                        android:id="@+id/topStreamsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/top_watched_channels"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/topStreamsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_stream_stat" />

                <TextView
                    android:id="@+id/topStreamsEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:text="@string/no_data"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hidden text view for backward compatibility -->
        <TextView
            android:id="@+id/screenTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
